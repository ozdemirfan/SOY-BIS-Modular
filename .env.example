# Kopyalayın: copy .env.example .env.local
#
# API kökü (zorunlu mantık — build’de JS içine gömülür):
# - Üretim, statik site ile API aynı host’ta: VITE_SOYBIS_API_BASE=/api
# - XAMPP (tam URL): VITE_SOYBIS_API_BASE=http://localhost/soybis/api
# - Vite dev (npm run dev): aşağıdaki proxy ile VITE_SOYBIS_API_BASE=/api kullanabilirsiniz.
VITE_SOYBIS_API_BASE=http://localhost/soybis/api

# Vite geliştirme sunucusu: tarayıcı /api/* isteklerini buraya yönlendirir.
# Örnek: Apache document root’ta proje http://localhost/soybis ise kök şu olmalı (sonda /api yok).
VITE_SOYBIS_API_PROXY_TARGET=http://localhost/soybis

# Farklı origin (ör. app ve API ayrı subdomain): tam API URL’si + sunucuda CORS ve
# session çerezi (SameSite/Secure) ayarları gerekir — bkz. docs/HOSTING_SHARED_DB.md bölüm 8.

# PHP API (Apache / sistem ortam değişkeni; Vite .env otomatik yüklemez):
# Hata ayıklamada JSON 500 yanıtına "detail" eklemek için: SOYBIS_API_DEBUG=1
